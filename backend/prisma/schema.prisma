generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Site {
  id             String    @id @default(uuid())
  name           String
  clientName     String
  address        String?
  budget         Float     @default(0)
  status         String    @default("RUNNING") // RUNNING, COMPLETED
  startDate      DateTime
  completionDate DateTime?
  description    String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  dayBooks            DayBook[]
  materialTransactions MaterialTransaction[]
  ledgers             Ledger[]
}

model DayBook {
  id              String   @id @default(uuid())
  siteId          String
  date            DateTime
  expenseType     String   // Labour, Cement, Sand, Steel, Diesel, Transport, Miscellaneous
  amount          Float
  description     String?
  paymentMode     String   // Cash, Bank Transfer, Cheque, UPI
  referenceNumber String?

  site            Site     @relation(fields: [siteId], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Ledger {
  id                 String   @id @default(uuid())
  type               String   // Party, Supplier, Contractor
  name               String
  contactPerson      String?
  phone              String?
  outstandingBalance Float    @default(0) // Positive means we owe them, Negative means they owe us
  siteId             String?
  
  site               Site?    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  transactions       LedgerTransaction[]
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model LedgerTransaction {
  id          String   @id @default(uuid())
  ledgerId    String
  date        DateTime
  type        String   // Debit, Credit
  amount      Float
  description String?
  
  ledger      Ledger   @relation(fields: [ledgerId], references: [id])
  
  createdAt   DateTime @default(now())
}

model Material {
  id           String   @id @default(uuid())
  name         String   // Cement, Bricks, Sand, Steel, Paint, Pipes
  unit         String   // bags, pieces, tons, liters, etc.
  currentStock Float    @default(0)
  lowStockAlert Float   @default(10)
  rate         Float?   @default(0)
  
  transactions MaterialTransaction[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MaterialTransaction {
  id          String   @id @default(uuid())
  materialId  String
  siteId      String?
  date        DateTime
  type        String   // StockIn, StockOut
  quantity    Float
  description String?
  
  material    Material @relation(fields: [materialId], references: [id])
  site        Site?    @relation(fields: [siteId], references: [id])
  
  createdAt   DateTime @default(now())
}

model BackupLog {
  id          String   @id @default(uuid())
  fileName    String
  fileUrl     String?  // Cloudinary URL if uploaded
  createdAt   DateTime @default(now())
}
